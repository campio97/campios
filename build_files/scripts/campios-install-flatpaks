#!/usr/bin/env bash
set -euo pipefail

DEFAULT_APPS_FILE="/usr/share/campios/flatpaks/default-apps.txt"
REMOVE_APPS_FILE="/usr/share/campios/flatpaks/remove-apps.txt"

read_apps() {
  local file="$1"
  [[ -f "$file" ]] || return 0

  while IFS= read -r app || [[ -n "$app" ]]; do
    [[ -z "$app" ]] && continue
    [[ "$app" =~ ^# ]] && continue
    echo "$app"
  done < "$file"
}

flatpak remote-add --system --if-not-exists flathub \
  https://dl.flathub.org/repo/flathub.flatpakrepo

# Rimuovi Flatpak indesiderati system-wide
while read -r app; do
  echo "Rimuovo Flatpak system-wide: $app"
  flatpak uninstall --system -y --noninteractive "$app" || true
done < <(read_apps "$REMOVE_APPS_FILE")

# Installa Flatpak predefiniti system-wide
while read -r app; do
  if flatpak info --system "$app" >/dev/null 2>&1; then
    echo "$app già installata"
    continue
  fi

  echo "Installo $app..."
  flatpak install --system -y --noninteractive flathub "$app"
done < <(read_apps "$DEFAULT_APPS_FILE")

flatpak uninstall --system -y --noninteractive --unused || true