#!/usr/bin/env bash
set -euo pipefail

APPS_FILE="/usr/share/campios/flatpaks/default-apps.txt"

flatpak remote-add --system --if-not-exists flathub \
  https://dl.flathub.org/repo/flathub.flatpakrepo

while read -r app; do
  [[ -z "$app" ]] && continue
  [[ "$app" =~ ^# ]] && continue

  if flatpak info --system "$app" >/dev/null 2>&1; then
    echo "$app già installata"
    continue
  fi

  echo "Installo $app..."
  flatpak install --system -y --noninteractive flathub "$app" || true
done < "$APPS_FILE"